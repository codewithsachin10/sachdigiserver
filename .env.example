# SachDeploy v1 Configuration
# Copy this file to .env before deploying

# Security & Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sachdeploy
JWT_SECRET_KEY=super-secret-sachdeploy-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server & Storage Configuration
PORT=7000
STORAGE_PATH=/app/storage
DATABASE_URL=sqlite:///app/storage/sachdeploy.db

# Docker Engine
DOCKER_HOST=unix://var/run/docker.sock

# Port Assignment Range for Deployed Applications
MIN_PORT=8001
MAX_PORT=8999
